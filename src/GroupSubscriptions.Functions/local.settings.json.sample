{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "Cosmos__Endpoint": "https://<your-cosmos-account>.documents.azure.com:443/",
    "Cosmos__Database": "groupsubscriptions",
    "Cosmos__Container": "subscriptions",
    "Apim__SubscriptionId": "<azure-subscription-id>",
    "Apim__ResourceGroup": "<resource-group-name>",
    "Apim__ServiceName": "<apim-service-name>",
    "DevPortal__Url": "https://<your-apim>.developer.azure-api.net"
  }
}
