####################################################################################################
# Environment configuration — single source of truth for all deployment/util scripts.
#
# Copy this file to `.env` (git-ignored) and fill in the values, or generate it with:
#     ./scripts/Deploy.ps1
#
# Every PowerShell script in this repo loads `.env` via scripts/lib/DotEnv.ps1, so you only set
# these values once. Values captured from a deployment (APIM/Function names, URLs) are filled in
# automatically by `Deploy.ps1 -Deploy`.
####################################################################################################

# --- Azure identity (GitHub OIDC / az login) -----------------------------------------------------
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --- Deployment target ---------------------------------------------------------------------------
# RESOURCE_PREFIX: 3-11 lowercase alphanumeric chars used to name all resources.
AZURE_RESOURCE_GROUP=rg-<prefix>-dev
AZURE_LOCATION=northeurope
RESOURCE_PREFIX=<prefix>

# --- API Management publisher --------------------------------------------------------------------
APIM_PUBLISHER_EMAIL=you@example.com
APIM_PUBLISHER_NAME=Group Subscriptions

# --- Populated from deployment outputs (leave blank until deployed) -------------------------------
# These embed the Bicep uniqueString() suffix and can only be known after a successful deploy.
APIM_SERVICE_NAME=
AZURE_FUNCTIONAPP_NAME=
FUNCTION_BASE_URL=
DEVPORTAL_URL=https://<your-apim>.developer.azure-api.net/

# --- Developer Portal E2E test credentials -------------------------------------------------------
DEVPORTAL_TEST_USERNAME=testuser@test.com
DEVPORTAL_TEST_PASSWROD=thepasswordhere!!